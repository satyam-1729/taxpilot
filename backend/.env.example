APP_ENV=dev
APP_SECRET=change-me-to-a-long-random-string

DATABASE_URL=postgresql+asyncpg://taxpilot:taxpilot@localhost:5432/taxpilot
REDIS_URL=redis://localhost:6379/0

# Path to Firebase service account JSON (Project settings → Service accounts → Generate private key).
# Lives in repo-root /secrets/ which is gitignored. Path is relative to backend/ (the cwd uvicorn runs from).
FIREBASE_SERVICE_ACCOUNT_PATH=../secrets/firebase-service-account.json
FIREBASE_PROJECT_ID=

# 32-byte key for encrypting PAN at rest. Rotate via re-encryption migration if this changes.
FIELD_ENCRYPTION_KEY=please-replace-with-a-random-32-byte-string

CORS_ORIGINS=["http://localhost:4200"]
